# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Services (isi setelah Johana & Nisrina deploy) ─────
# PENTING: base URL saja, JANGAN pakai suffix /docs — pipeline
# menambahkan path sendiri (mis. /detect-sahi, /rag/...).
YOLO_SERVICE_URL=https://computer-vision-safety-hazard-production.up.railway.app
RAG_SERVICE_URL=https://mattel-ehss-rag-production.up.railway.app

# ── Email (Resend HTTPS API — Railway blokir SMTP di plan non-Pro) ─
RESEND_API_KEY=your-resend-api-key-here
MAIL_FROM=noreply@your-verified-domain.com

# ── Environment ───────────────────────────────────────────
ENV=development
